<Page x:Class="SneakerShop.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:model="clr-namespace:SneakerShop.Model"
      Title="MainPage">
    <Grid Style="{StaticResource PageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Каталог цифровых клонов" Style="{StaticResource HeaderTextStyle}" />
                <WrapPanel>
                    <TextBox x:Name="SearchTb" Width="210" Margin="0,0,8,8" Style="{StaticResource InputStyle}" TextChanged="FilterChanged" />
                    <ComboBox x:Name="ToxicityCb" Width="170" Margin="0,0,8,8" SelectionChanged="FilterChanged" Style="{StaticResource InputStyle}" />
                    <ComboBox x:Name="SortCb" Width="170" Margin="0,0,8,8" SelectionChanged="FilterChanged" Style="{StaticResource InputStyle}" />
                    <Button Content="Мои заказы" Width="130" Margin="0,0,0,8" Style="{StaticResource AccentButtonStyle}" Click="OrdersBtn_Click" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <ListView x:Name="ClonesLv" Grid.Row="1" ItemsSource="{Binding}" Background="#1E1E1E" BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type model:Clone}">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="96" Height="96" CornerRadius="8" Background="#2A2A2A">
                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,12,0">
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#D0D0D0" Margin="0,4,0,6" />
                                <TextBlock Text="{Binding Intelligence, StringFormat=Интеллект: {0}}" Foreground="#BDBDBD" />
                                <TextBlock Text="{Binding Toxicity, StringFormat=Токсичность: {0}}" Foreground="#BDBDBD" />
                                <TextBlock Text="{Binding Charisma, StringFormat=Харизма: {0}}" Foreground="#BDBDBD" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Price, StringFormat={}{0:N2} ₽}" Foreground="#C68CFF" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                                <Button Content="Купить" Margin="0,8,0,0" Tag="{Binding}" Style="{StaticResource AccentButtonStyle}" Click="BuyBtn_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
