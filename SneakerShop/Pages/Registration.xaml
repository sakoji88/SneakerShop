<Page x:Class="SneakerShop.Pages.Registration"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Registration">
    <Grid Style="{StaticResource PageGridStyle}">
        <Border Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Регистрация" Style="{StaticResource HeaderTextStyle}" />

                    <TextBlock Text="Имя" Style="{StaticResource LabelTextStyle}" />
                    <TextBox x:Name="NameTb" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Логин" Style="{StaticResource LabelTextStyle}" />
                    <TextBox x:Name="LoginTb" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Email" Style="{StaticResource LabelTextStyle}" />
                    <TextBox x:Name="EmailTb" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Пароль" Style="{StaticResource LabelTextStyle}" />
                    <PasswordBox x:Name="PasswordPb" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Повтор пароля" Style="{StaticResource LabelTextStyle}" />
                    <PasswordBox x:Name="RepeatPasswordPb" Style="{StaticResource InputStyle}" />

                    <Button Content="Создать аккаунт" Style="{StaticResource AccentButtonStyle}" Click="RegisterBtn_Click" />
                    <Button Content="Назад" Style="{StaticResource GhostButtonStyle}" Click="BackBtn_Click" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
