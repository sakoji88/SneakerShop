<Page x:Class="SneakerShop.Pages.Orders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Orders">
    <Grid Style="{StaticResource PageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="Мои покупки" Style="{StaticResource HeaderTextStyle}" DockPanel.Dock="Left" />
                <Button Content="Назад в каталог" DockPanel.Dock="Right" Style="{StaticResource AccentButtonStyle}" Click="BackBtn_Click" />
            </DockPanel>
        </Border>

        <DataGrid x:Name="OrdersDg"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Background="#1E1E1E"
                  Foreground="White"
                  BorderThickness="0"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" />
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}" Width="180" />
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat={}{0:N2} ₽}" Width="160" />
                <DataGridTextColumn Header="Позиций" Binding="{Binding ItemCount}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
